   "source": [
    "# 🧠 A.X.I.S — Autonomous eXecution & Intelligence System\n",
    "\n",
    "**Run each cell from top to bottom.**  \n",
    "After Cell 5, you'll get a public URL — open it in any browser to start chatting.\n",
    "\n",
    "| Feature | Details |\n",
    "|---|---|\n",
    "| LLM | Ollama (`llama3:8b`) on Colab T4 GPU |\n",
    "| Memory | ChromaDB persistent vector store |\n",
    "| Backend | FastAPI + Socket.io |\n",
    "| Tunnel | ngrok public HTTPS URL |"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ════════════════════════════════════════════════\n",
    "# CELL 1 — Install Ollama & start the server\n",
    "# ════════════════════════════════════════════════\n",
    "import subprocess, os, time\n",
    "\n",
    "print('📦 Installing Ollama...')\n",
    "os.system('curl -fsSL https://ollama.com/install.sh | sh')\n",
    "\n",
    "print('🚀 Starting Ollama server in background...')\n",
    "subprocess.Popen(['ollama', 'serve'],\n",
    "                 stdout=subprocess.DEVNULL,\n",
    "                 stderr=subprocess.DEVNULL)\n",
    "time.sleep(4)  # Give it time to bind the port\n",
    "\n",
    "# Quick check\n",
    "import requests\n",
    "try:\n",
    "    r = requests.get('http://localhost:11434')\n",
    "    print('✅ Ollama running:', r.text.strip())\n",
    "except Exception as e:\n",
    "    print('❌ Ollama not responding:', e)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ════════════════════════════════════════════════\n",
    "# CELL 2 — Pull the LLM model\n",
    "# Takes ~5 min on first run (downloads 4.7 GB).\n",
    "# Subsequent runs reuse the cached weights.\n",
    "# ════════════════════════════════════════════════\n",
    "MODEL = 'llama3:8b'   # Change to 'mistral' or 'gemma:2b' for lighter models\n",
    "\n",
    "print(f'⬇️  Pulling {MODEL} — this may take a few minutes on first run...')\n",
    "result = subprocess.run(['ollama', 'pull', MODEL], capture_output=True, text=True)\n",
    "print(result.stdout[-500:] if result.stdout else 'No output')\n",
    "\n",
    "# Verify\n",
    "models = subprocess.run(['ollama', 'list'], capture_output=True, text=True)\n",
    "print('\\n📋 Installed models:')\n",
    "print(models.stdout)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ════════════════════════════════════════════════\n",
    "# CELL 3 — Install Python packages\n",
    "# ════════════════════════════════════════════════\n",
    "print('📦 Installing Python dependencies...')\n",
    "os.system('pip install -q fastapi uvicorn python-socketio chromadb pyngrok requests')\n",
    "print('✅ All packages installed.')"
   ]
  },
